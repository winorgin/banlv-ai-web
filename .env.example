# ============================================
# Supabase 配置
# ============================================
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ============================================
# Discord 配置
# ============================================
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_discord_guild_id

# ============================================
# AI 服务配置
# ============================================
# OpenRouter (用于 Discord)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-3-sonnet

# 豆包 AI (用于 Web)
ARK_API_KEY=your_ark_api_key
ENDPOINT_ID=your_endpoint_id

# ============================================
# 支付配置
# ============================================
CREEM_API_KEY=your_creem_api_key
CREEM_WEBHOOK_SECRET=your_creem_webhook_secret
CREEM_PRODUCT_ID=your_product_id

# ============================================
# 服务器配置
# ============================================
PORT=8044
NODE_ENV=development
HOST=localhost

# ============================================
# 会话配置
# ============================================
# 会话签名密钥建议至少使用 32 字节随机字符串
SESSION_SECRET=replace_with_a_random_string_of_at_least_32_bytes
SESSION_MAX_AGE=86400000

# JWT 配置
# HS256 建议至少使用 32 字节随机字符串
JWT_SECRET=replace_with_a_random_string_of_at_least_32_bytes
JWT_EXPIRES_IN=7d

# ============================================
# 功能开关
# ============================================
ENABLE_DISCORD=true
ENABLE_WEB=true
ENABLE_PAYMENT=true
ENABLE_VOICE=false
ENABLE_IMAGE_GEN=false

# ============================================
# 系统配置
# ============================================
# DOL 配置
DAILY_DOL_AMOUNT=10
DOL_PER_MESSAGE=1
INTIMACY_PER_MESSAGE=1

# 主动消息间隔（秒）
PROACTIVE_CHAT_COOLDOWN=3600

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# CORS 配置
# ============================================
CORS_ORIGIN=http://localhost:8044
CORS_CREDENTIALS=true

# ============================================
# 代理配置（可选）
# ============================================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============================================
# Redis 配置（多服务器部署）
# ============================================
# 单服务器模式：不需要配置（自动使用本地内存）
# 多服务器模式：配置 Redis URL 以启用 Pub/Sub 消息广播
# REDIS_URL=redis://localhost:6380
# REDIS_URL=redis://:password@redis-host:6380
# REDIS_URL=rediss://redis-cloud-host:6380  # SSL 连接
